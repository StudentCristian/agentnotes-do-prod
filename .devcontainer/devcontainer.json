{
  "name": "AgentNotes Production Parity",
  "dockerComposeFile": "../docker-compose.dev.yml",
  "service": "app",
  "runServices": ["app", "postgres", "minio", "minio-init"],
  "workspaceFolder": "/workspace",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "shutdownAction": "stopCompose",
  "remoteUser": "node",
  "forwardPorts": [3000, 5432, 9000, 9001],
  "portsAttributes": {
    "3000": {
      "label": "Next.js"
    },
    "5432": {
      "label": "PostgreSQL"
    },
    "9000": {
      "label": "MinIO API"
    },
    "9001": {
      "label": "MinIO Console"
    }
  },
  "containerEnv": {
    "SHELL": "/bin/bash"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n"
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers"
      ]
    }
  }
}